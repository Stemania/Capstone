{
  "info": {
    "name": "BMSC Production Scheduling API",
    "description": "Brothers Machine Shop and Services Corporation — REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@bmsc.local\",\n  \"password\": \"Admin123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{refreshToken}}" }],
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newworker@bmsc.local\",\n  \"password\": \"Worker123!\",\n  \"fullName\": \"New Worker\",\n  \"role\": \"PRODUCTION_WORKER\",\n  \"skills\": [\"milling\", \"welding\"]\n}"
            },
            "url": "{{baseUrl}}/users"
          }
        }
      ]
    },
    {
      "name": "Workers",
      "item": [
        {
          "name": "List Workers",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/workers"
          }
        },
        {
          "name": "Suggest Workers",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operations\": [\"Milling\", \"Grinding\"]\n}"
            },
            "url": "{{baseUrl}}/workers/suggest"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/clients"
          }
        },
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Client Corp\",\n  \"contact\": \"09170000000\"\n}"
            },
            "url": "{{baseUrl}}/clients"
          }
        }
      ]
    },
    {
      "name": "Job Orders",
      "item": [
        {
          "name": "List Job Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/job-orders"
          }
        },
        {
          "name": "Create Job Order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"<client-id>\",\n  \"title\": \"Test Job\",\n  \"description\": \"Test description\",\n  \"dueDate\": \"2026-08-01\",\n  \"assignedWorkerId\": \"<worker-id>\",\n  \"operations\": [\n    { \"seq\": 1, \"name\": \"Milling\" },\n    { \"seq\": 2, \"name\": \"Grinding\" }\n  ]\n}"
            },
            "url": "{{baseUrl}}/job-orders"
          }
        },
        {
          "name": "Get Job Order",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/job-orders/<job-id>"
          }
        },
        {
          "name": "Reassign Worker",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"assignedWorkerId\": \"<worker-id>\"\n}"
            },
            "url": "{{baseUrl}}/job-orders/<job-id>/reassign"
          }
        }
      ]
    },
    {
      "name": "Operations",
      "item": [
        {
          "name": "Start Operation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timestamp\": \"2026-07-16T14:30:00Z\"\n}"
            },
            "url": "{{baseUrl}}/operations/<operation-id>/start"
          }
        },
        {
          "name": "Complete Operation",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"timestamp\": \"2026-07-16T16:30:00Z\"\n}"
            },
            "url": "{{baseUrl}}/operations/<operation-id>/complete"
          }
        }
      ]
    },
    {
      "name": "Tools",
      "item": [
        {
          "name": "List Tools",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/tools"
          }
        },
        {
          "name": "Create Tool",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Tool\",\n  \"code\": \"TOOL-NEW-001\"\n}"
            },
            "url": "{{baseUrl}}/tools"
          }
        },
        {
          "name": "Scan Tool",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"TOOL-MILL-001\"\n}"
            },
            "url": "{{baseUrl}}/tools/scan"
          }
        },
        {
          "name": "List Tool Events",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/tools/events"
          }
        },
        {
          "name": "Get Tool QR",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/tools/<tool-id>/qr"
          }
        }
      ]
    }
  ]
}
